generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================================================================
// ENUMS
// =====================================================================================

enum UserRole {
  CUSTOMER
  ADMIN
}

enum ProductListingStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
}

enum PaymentMethod {
  STRIPE
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum SellStatus {
  SUBMITTED
  RECEIVED
  INSPECTION
  OFFER_MADE
  PAID
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// =====================================================================================
// CORE PLATFORM ENTITIES
// =====================================================================================

model User {
  id                            String    @id @default(uuid())
  email                         String    @unique
  passwordHash                  String
  firstName                     String
  lastName                      String
  phone                         String?
  isEmailVerified               Boolean   @default(false)
  emailVerifiedAt               DateTime?
  emailVerificationOtpHash      String?
  emailVerificationOtpExpiresAt DateTime?
  passwordResetOtpHash          String?
  passwordResetOtpExpiresAt     DateTime?
  passwordResetOtpVerifiedAt    DateTime?
  role                          UserRole  @default(CUSTOMER)
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  userAddresses UserAddress[]
  cart          Cart?
  orders        Order[]
  reviews       Review[]
  sellRequests  SellRequest[]
  isDeleted     Boolean       @default(false)
  deletedAt     DateTime?
}

model UserAddress {
  id        String   @id @default(uuid())
  street    String
  city      String
  state     String
  zipCode   String
  country   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]   @relation("OrderAddress")
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([userId])
}

// =====================================================================================
// ADMIN MANAGED LOOKUPS & ATTRIBUTES
// =====================================================================================

model Category {
  id         String                    @id @default(uuid())
  name       String                    @unique
  products   Product[]
  promoCodes PromoCodeCategoryBridge[]
  isDeleted  Boolean                   @default(false)
  deletedAt  DateTime?
}


model Series {
  id        String        @id @default(uuid())
  name      String        @unique
  models    DeviceModel[]
  products  Product[]
  isDeleted Boolean       @default(false)
  deletedAt DateTime?
}

model DeviceModel {
  id        String    @id @default(uuid())
  name      String    @unique
  seriesId  String
  series    Series    @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  products  Product[]
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([seriesId])
}

model Condition {
  id              String           @id @default(uuid())
  name            String           @unique
  basePrice       Decimal          @default(0) @db.Decimal(12, 2)
  productVariants ProductVariant[]
  sellRequests    SellRequest[]
  isDeleted       Boolean          @default(false)
  deletedAt       DateTime?

  @@index([name])
}

model Color {
  id              String           @id @default(uuid())
  name            String           @unique
  productVariants ProductVariant[]
  isDeleted       Boolean          @default(false)
  deletedAt       DateTime?
}

model StorageOption {
  id              String           @id @default(uuid())
  name            String           @unique
  productVariants ProductVariant[]
  isDeleted       Boolean          @default(false)
  deletedAt       DateTime?
}

model RamOption {
  id              String           @id @default(uuid())
  name            String           @unique
  productVariants ProductVariant[]
  isDeleted       Boolean          @default(false)
  deletedAt       DateTime?
}

// =====================================================================================
// PRODUCT & INVENTORY SYSTEM
// =====================================================================================

model Product {
  id            String               @id @default(uuid())
  title         String
  description   String
  introduction  String?
  basePrice     Decimal              @db.Decimal(12, 2)
  listingStatus ProductListingStatus @default(INACTIVE)

  categoryId    String
  seriesId      String
  deviceModelId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category    Category    @relation(fields: [categoryId], references: [id])
  series      Series      @relation(fields: [seriesId], references: [id])
  deviceModel DeviceModel @relation(fields: [deviceModelId], references: [id])

  productGalleries ProductGallery[]
  productFaqs      ProductFaq[]
  productVariants  ProductVariant[]
  highlights       ProductHighlight[]
  specifications   ProductSpecification[]
  reviews          Review[]
  isDeleted        Boolean                @default(false)
  deletedAt        DateTime?

  @@index([categoryId])
  @@index([seriesId])
  @@index([deviceModelId])
  @@index([listingStatus])
}

model ProductHighlight {
  id           String  @id @default(uuid())
  productId    String
  title        String
  description  String
  iconUrl      String?
  displayOrder Int     @default(0)

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([productId])
}

model ProductSpecification {
  id           String @id @default(uuid())
  productId    String
  name         String
  value        String
  displayOrder Int    @default(0)

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([productId])
}

model ProductGallery {
  id           String    @id @default(uuid())
  productId    String
  imageUrl     String
  displayOrder Int       @default(0)
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?

  @@index([productId])
}

model ProductFaq {
  id        String    @id @default(uuid())
  productId String
  question  String
  answer    String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([productId])
}

model ProductVariant {
  id              String               @id @default(uuid())
  productId       String
  colorId         String
  storageOptionId String
  ramOptionId     String
  conditionId     String
  sku             String               @unique
  finalPrice      Decimal              @db.Decimal(12, 2)
  stockQuantity   Int                  @default(0)
  variantStatus   ProductListingStatus @default(INACTIVE)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  color         Color         @relation(fields: [colorId], references: [id])
  storageOption StorageOption @relation(fields: [storageOptionId], references: [id])
  ramOption     RamOption     @relation(fields: [ramOptionId], references: [id])
  condition     Condition     @relation(fields: [conditionId], references: [id])

  cartItems  CartItem[]
  orderItems OrderItem[]
  isDeleted  Boolean     @default(false)
  deletedAt  DateTime?

  @@index([productId])
  @@index([conditionId])
}

// =====================================================================================
// ORDER, CART & PAYMENTS (STRIPE EXCLUSIVE)
// =====================================================================================

model Cart {
  id        String   @id @default(uuid())
  userId    String?  @unique
  sessionId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartItems CartItem[]
  isDeleted Boolean    @default(false)
  deletedAt DateTime?
}

model CartItem {
  id               String   @id @default(uuid())
  cartId           String
  productVariantId String
  quantity         Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cart           Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  isDeleted      Boolean        @default(false)
  deletedAt      DateTime?

  @@index([cartId])
}

model Order {
  id            String      @id @default(uuid())
  stringId      String      @unique
  userId        String
  orderStatus   OrderStatus @default(PENDING)
  totalPrice    Decimal     @db.Decimal(12, 2)
  shippingCost  Decimal     @default(0) @db.Decimal(12, 2)
  discountTotal Decimal     @default(0) @db.Decimal(12, 2)
  promoCodeUsed String?

  // Unified single delivery address reference linking to fulfillment destination
  addressId String

  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(STRIPE)
  paymentIntentId String?
  trackingNumber  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  address    UserAddress @relation("OrderAddress", fields: [addressId], references: [id])
  orderItems OrderItem[]
  isDeleted  Boolean     @default(false)
  deletedAt  DateTime?

  @@index([userId])
  @@index([addressId])
  @@index([orderStatus])
  @@index([paymentIntentId])
}

model OrderItem {
  id               String  @id @default(uuid())
  orderId          String
  productVariantId String
  quantity         Int
  priceAtPurchase  Decimal @db.Decimal(12, 2)

  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
  isDeleted      Boolean        @default(false)
  deletedAt      DateTime?

  @@index([orderId])
  @@index([productVariantId])
}

// =====================================================================================
// PROMOTIONS, FEEDBACK & C2B RE-COMMERCE
// =====================================================================================

model PromoCode {
  id                String       @id @default(uuid())
  code              String       @unique
  discountType      DiscountType @default(PERCENTAGE)
  discountValue     Decimal      @db.Decimal(12, 2)
  minOrderValue     Decimal?     @db.Decimal(12, 2)
  maxUsageCount     Int?
  currentUsageCount Int          @default(0)
  startDate         DateTime
  expiryDate        DateTime
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  applicableCategories PromoCodeCategoryBridge[]
  isDeleted            Boolean                   @default(false)
  deletedAt            DateTime?
}

model PromoCodeCategoryBridge {
  id          String   @id @default(uuid())
  promoCodeId String
  categoryId  String
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@unique([promoCodeId, categoryId])
}

model Review {
  id        String       @id @default(uuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([productId])
}

model SellRequest {
  id             String     @id @default(uuid())
  stringId       String     @unique
  userId         String?
  firstName      String
  lastName       String
  email          String
  phone          String
  deviceName     String
  conditionId    String
  baseOfferPrice Decimal    @db.Decimal(12, 2)
  status         SellStatus @default(SUBMITTED)
  serialNumber   String?
  trackingNumber String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  condition Condition     @relation(fields: [conditionId], references: [id])
  images    DeviceImage[]
  isDeleted Boolean       @default(false)
  deletedAt DateTime?

  @@index([userId])
  @@index([conditionId])
}

model DeviceImage {
  id            String      @id @default(uuid())
  sellRequestId String
  imageUrl      String
  sellRequest   SellRequest @relation(fields: [sellRequestId], references: [id], onDelete: Cascade)
  isDeleted     Boolean     @default(false)
  deletedAt     DateTime?

  @@index([sellRequestId])
}
