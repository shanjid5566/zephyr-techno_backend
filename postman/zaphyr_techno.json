              "path": ["api", "auth", "resend-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"type\": \"password-reset\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
